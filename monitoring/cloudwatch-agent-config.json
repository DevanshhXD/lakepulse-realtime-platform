{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/spark/*.log",
            "log_group_name": "lakepulse-spark-logs",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/airflow/*.log",
            "log_group_name": "lakepulse-airflow-logs",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  },

  "metrics": {
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}"
    },

    "metrics_collected": {
      "cpu": {
        "measurement": [
          "cpu_usage_idle",
          "cpu_usage_user"
        ],

        "metrics_collection_interval": 60
      },

      "mem": {
        "measurement": [
          "mem_used_percent"
        ],

        "metrics_collection_interval": 60
      }
    }
  }
}